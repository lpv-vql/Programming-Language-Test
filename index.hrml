<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>Page Title</title>
  <style>
    body {
      font-family: sans-serif;
      margin: 0;
      padding: 20px;
      background-color: #f5f5f5;
    }
    .code {
      width: 100%;
      overflow-y: hidden;
      border: none;
      resize: none;
    }
  </style>
</head>
<body>
  <textarea class="code"></textarea>

  <script>
    const tx = document.querySelector('.code');
    tx.addEventListener('input', function() {
      this.style.height = 'auto';
      this.style.height = this.scrollHeight + 'px';
    });
  </script>
</body>
</html>
